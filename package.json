{
  "name": "saju",
  "private": true,
  "version": "0.1.0",
  "description": "Saju report web app with repository and application harnesses.",
  "type": "module",
  "scripts": {
    "app:harness": "tsx tools/application-harness/index.ts",
    "app:harness:json": "tsx tools/application-harness/index.ts --json",
    "build": "next build",
    "dev": "next dev",
    "repo:harness": "tsx tools/repository-harness/index.ts",
    "repo:harness:json": "tsx tools/repository-harness/index.ts --json",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run repo:harness && npm run app:harness"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "next": "^14.2.35",
    "postcss": "^8.5.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17"
  }
}
